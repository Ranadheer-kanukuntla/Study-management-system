doctype html
html(lang="en")
  head
    title Academic Login | StudyLink
    link(rel="stylesheet", href="/css/style.css")
  body.min-h-screen.w-full.bg-cover.bg-center.relative.flex.flex-col.justify-between(style="background-image: url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80');")
    
    .absolute.inset-0.bg-gradient-to-b.from-blue-900_via-blue-900.to-gray-900.opacity-80.z-0
    
    .relative.z-10.flex-grow.flex.flex-col.items-center.justify-center.text-center.px-6.pt-10
      .w-16.h-16.bg-white.rounded-full.flex.items-center.justify-center.text-blue-600.font-bold.text-3xl.shadow-lg.mb-6 S
      h1.text-4xl.font-extrabold.text-white.tracking-tight.mb-4(class="md:text-5xl") StudyLink Academic Portal
      p.text-blue-100.text-lg.max-w-2xl Access your courses, secure grades, and campus resources centrally.

    .relative.z-10.w-full.flex.justify-center.pb-12.px-4
      .w-full.max-w-md.bg-white.p-8.rounded-2xl.shadow-2xl.border-t-4.border-blue-600
        
        .text-center.mb-6
          h2.text-2xl.font-bold.text-gray-900 Sign In
          p.text-gray-500.text-sm.mt-1 Use your institutional credentials
        
        form#loginForm
          .flex.p-1.bg-gray-100.rounded-lg.mb-6
            button#studentRole.role-btn.flex-1.py-2.bg-white.text-blue-600.rounded-md.shadow-sm.text-sm.font-bold.transition(type="button") Student
            button#educatorRole.role-btn.flex-1.py-2.text-gray-500.rounded-md.text-sm.font-bold.transition(class="hover:text-gray-700", type="button") Educator

          //- Input Fields
          .mb-4
            label.block.text-sm.font-semibold.text-gray-700.mb-1(for="email") Email Address
            input#email.w-full.border.border-gray-300.p-3.rounded-lg.bg-gray-50.transition(class="focus:ring-2 focus:ring-blue-600 focus:bg-white outline-none", type="email" placeholder="e.g. ananya@university.com" required)
          
          .mb-6
            .flex.justify-between.items-center.mb-1
              label.block.text-sm.font-semibold.text-gray-700(for="password") Password
              a.text-xs.text-blue-600(class="hover:underline", href="#") Forgot Password?
            input#password.w-full.border.border-gray-300.p-3.rounded-lg.bg-gray-50.transition(class="focus:ring-2 focus:ring-blue-600 focus:bg-white outline-none", type="password" placeholder="••••••••" required)
          
          button.w-full.bg-blue-600.text-white.py-3.rounded-lg.font-bold.shadow-md.transition(class="hover:bg-blue-700", type="submit") Secure Login

        .mt-6.pt-4.border-t.border-gray-100.text-center
          p.text-xs.text-gray-500 Having trouble signing in? 
            a.text-blue-600.font-medium(class="hover:underline", href="#") Contact IT Helpdesk

    script.
      let role = 'student';
      
      document.querySelectorAll('.role-btn').forEach(btn => btn.onclick = (e) => {
          document.querySelectorAll('.role-btn').forEach(b => { 
              b.className = 'role-btn flex-1 py-2 text-gray-500 rounded-md text-sm font-bold transition hover:text-gray-700'; 
          });
          e.target.className = 'role-btn flex-1 py-2 bg-white text-blue-600 rounded-md shadow-sm text-sm font-bold transition';
          role = e.target.innerText.toLowerCase();
      });

      // Secure Login Request
      document.getElementById('loginForm').onsubmit = async (e) => {
          e.preventDefault();
          const email = document.getElementById('email').value;
          const password = document.getElementById('password').value;

          const res = await fetch('/api/login', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({ email, password, role })
          });
          
          const data = await res.json();
          if(data.token) {
              localStorage.setItem('sms_token', data.token);
              window.location.href = `/${role}/dashboard`;
          } else { 
              alert(data.message || "Authentication failed. Please check your credentials."); 
          }
      };