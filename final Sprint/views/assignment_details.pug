doctype html
html(lang="en")
  head
    title Assignment | StudyLink
    link(rel="stylesheet" href="/css/style.css")
  body.bg-gray-50
    include navbar
    main.max-w-3xl.mx-auto.pt-24.px-4.pb-12(class="sm:px-6")
      a.text-blue-600.text-sm(class="hover:underline" href="/student/dashboard") ← Back to Dashboard
      .bg-white.rounded-2xl.shadow-sm.border.p-6.mt-6(class="sm:p-8")
        .flex.justify-between.items-start.gap-4
          div
            h1.text-2xl.font-bold= assignment.title
            p.text-sm.text-gray-400.mt-1 #{assignment.course} · Due #{assignment.dueDate}
          span.shrink-0.text-xs.font-bold.px-3.py-1.rounded-full(class=submission.status === 'Completed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700')= submission.status
 
        p.text-gray-600.mt-6.leading-relaxed= assignment.description
      
      .mt-8
        if submission.status === 'Completed'
          .grid.gap-6.grid-cols-1(class="md:grid-cols-2")
            .bg-green-50.p-6.rounded-2xl.border.border-green-200
              p.font-bold.text-green-800 ✔ Submitted
              p.text-xs.text-gray-500.mt-1= submission.submissionDate
              if submission.filePath
                a.text-xs.text-blue-600.block.mt-2(href=submission.filePath target="_blank") View uploaded file →
            if submission.grade
              .bg-white.p-6.rounded-2xl.border.shadow-sm
                p.font-bold.mb-3 Grade & Feedback
                span.text-5xl.font-black.text-blue-600= submission.grade
                p.text-sm.text-gray-600.mt-3.leading-relaxed= submission.feedback
        else
          .bg-blue-50.border-2.border-dashed.border-blue-200.rounded-2xl.p-8.text-center(class="sm:p-10")
            h3.font-bold.text-blue-900.mb-2 Submit Your Work
            p.text-sm.text-gray-500.mb-6 Attach a file or just click Submit to mark as complete
            form#submitForm(enctype="multipart/form-data")
              input.w-full.border.border-gray-200.rounded-xl.px-3.py-2.text-sm.mb-5.bg-white(type="file" name="submissionFile" accept=".pdf,.doc,.docx,.txt,.zip,.py,.js")
              br
              button.w-full.bg-blue-600.text-white.px-8.py-3.rounded-xl.font-bold.text-sm(class="sm:w-auto hover:bg-blue-700 transition" type="submit") Submit Now

  script.
    document.getElementById('submitForm').onsubmit = async e => {
      e.preventDefault();
      const fd = new FormData(e.target);
      fd.set('assignmentID', '!{assignment.assignmentID}');
      const res = await fetch('/api/submit', { method: 'POST', body: fd });
      if (res.ok) location.reload();
      else alert('Submission failed.');
    };